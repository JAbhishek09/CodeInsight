# backend/.env.example — copy to .env and fill in values
# NEVER commit .env to Git

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/codeinsight

# Auth
JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_EXPIRES_IN=7d

# AI — get free key at aistudio.google.com (no card required)
GEMINI_API_KEY=<your-gemini-api-key>

# Optional: LeetCode session cookie for deeper submission history (up to 40)
# Obtain by: F12 → Application → Cookies → leetcode.com → LEETCODE_SESSION
# Do NOT store this in DB — keep it in your own local .env only
LEETCODE_SESSION=

# Optional but STRONGLY RECOMMENDED for production:
# Chrome Extension ID — locks CORS to YOUR specific extension only.
# Without this, any Chrome extension can POST to your backend.
# Find it at chrome://extensions → enable Developer mode → copy the ID.
# Leave blank in local development to allow all extension origins.
EXTENSION_ID=
