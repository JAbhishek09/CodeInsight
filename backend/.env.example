# backend/.env.example — copy to .env and fill in values
# NEVER commit .env to Git — it is already in .gitignore

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/codeinsight

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_EXPIRES_IN=7d

# ─── AI ───────────────────────────────────────────────────────────────────────
# Get a free key at aistudio.google.com (no card required)
GEMINI_API_KEY=<your-gemini-api-key>

# ─── LeetCode Session (optional) ─────────────────────────────────────────────
# Required for:
#   • Historical import (Phase 1B + 1C) — importing submission code
#   • Viewing problems beyond the public last-20 limit
#
# How to obtain:
#   1. Open leetcode.com and log in
#   2. Open DevTools (F12) → Application tab → Cookies → https://leetcode.com
#   3. Copy the value of the LEETCODE_SESSION cookie
#
# IMPORTANT: Do NOT store this in the database. Keep it only in your local .env.
# LeetCode sessions expire after ~2 weeks; you'll need to refresh it periodically.
LEETCODE_SESSION=

# ─── Chrome Extension Security (STRONGLY RECOMMENDED for production) ──────────
#
# BUG-EXT-006 FIX: Without this, ANY Chrome extension installed in your browser
# can POST to the CodeInsight backend using your JWT. An extension ID locks CORS
# to YOUR specific CodeInsight extension only.
#
# How to find your Extension ID:
#   1. Open chrome://extensions
#   2. Enable "Developer mode" (toggle in the top-right corner)
#   3. Find "CodeInsight" in the list
#   4. Copy the ID string shown beneath the extension name
#      (format: 32 lowercase letters, e.g. "abcdefghijklmnopabcdefghijklmnop")
#
# Leave BLANK in local development — all chrome-extension:// origins are allowed
# when this variable is not set (safe for localhost, not safe for production).
#
# In production (Render, Railway, Fly.io, etc.) always set this.
EXTENSION_ID=
