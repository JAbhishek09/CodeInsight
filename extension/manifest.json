{
  "manifest_version": 3,
  "name": "CodeInsight – LeetCode Sync",
  "version": "1.2.0",
  "description": "Automatically captures your LeetCode submissions and syncs them to CodeInsight for AI-powered analysis.",

  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/bridge.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CodeInsight"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
